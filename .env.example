# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — Project Settings → API → service_role (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Spline scene URL (code export)
NEXT_PUBLIC_SPLINE_SCENE_URL=https://prod.spline.design/vCEn64MbFJ38qnjV/scene.splinecode

# iframe fallback if WebGL fails (basketball viewer — Phase 1 hero)
NEXT_PUBLIC_SPLINE_FALLBACK_EMBED_URL=https://my.spline.design/floatingbasketball-2e7G7zCpIzx26IAKccqGzzwC/

# Phase 2: export strand scene from Spline (bead_00…bead_47) — see src/lib/spline-strand.ts
# NEXT_PUBLIC_SPLINE_STRAND_SCENE_URL=https://prod.spline.design/YOUR_ID/scene.splinecode

# Phase 3: create staff user in Supabase → Authentication → Users → Add user
# /pos and /admin require login when Supabase is configured

# Phase 4: store branding + QR code (set APP_URL to your Vercel domain)
NEXT_PUBLIC_STORE_NAME=GemOps
NEXT_PUBLIC_STORE_TAGLINE=Design your bracelet in-store
NEXT_PUBLIC_APP_URL=https://gemops.vercel.app
